{
  "name": "soybean-ui",
  "version": "0.29.0-beta.13",
  "private": true,
  "description": "SoybeanUI is built on top of SoybeanHeadless, providing a collection of styled components for Vue 3.",
  "homepage": "https://github.com/soybeanjs/soybean-ui",
  "bugs": {
    "url": "https://github.com/soybeanjs/soybean-ui/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "url": "https://github.com/soybeanjs/soybean-ui.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:headless && pnpm build:ui && pnpm build:sbean",
    "build:docs": "pnpm --filter @soybeanjs/ui-docs build",
    "build:headless": "pnpm --filter @soybeanjs/headless build",
    "build:libs": "pnpm --filter @soybeanjs/shadcn-theme build && pnpm --filter @soybeanjs/unocss-shadcn build",
    "build:playground": "pnpm --filter @soybeanjs/ui-playground build",
    "build:sbean": "pnpm --filter sbean build",
    "build:ui": "pnpm --filter @soybeanjs/ui build",
    "commit": "soy git-commit",
    "dev:docs": "pnpm --filter @soybeanjs/ui-docs dev",
    "dev:playground": "pnpm --filter @soybeanjs/ui-playground dev",
    "fmt": "vp fmt",
    "lint": "vp lint --fix && pnpm lint:vue",
    "lint:vue": "eslint packages/ --ext .vue --fix",
    "prepare": "pnpm build:libs",
    "publish-pkg": "pnpm publish -r --access public",
    "release": "soy release -e 'pnpm release-execute'",
    "release-execute": "pnpm soy changelog && pnpm sui skills && pnpm sui changelog && pnpm sui changelog-translate && pnpm sync-template-versions",
    "stub": "tsx scripts/stub.ts",
    "sui": "tsx scripts/cli.ts",
    "sync-template-versions": "tsx scripts/sync-template-versions.ts",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r typecheck",
    "upkg": "soy ncu"
  },
  "dependencies": {
    "@soybeanjs/utils": "^0.1.1"
  },
  "devDependencies": {
    "@soybeanjs/cli": "^1.7.2",
    "@soybeanjs/eslint-config-vue": "^0.1.1",
    "@soybeanjs/oxc-config": "^0.2.3",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@11.7.0"
}
