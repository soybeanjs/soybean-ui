{
  "name": "@soybeanjs/ui-docs",
  "version": "0.29.0-beta.9",
  "private": true,
  "description": "SoybeanUI Docs is a documentation for SoybeanUI. It is designed to be easy to use and understand.",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm build:registry && vite-ssg build",
    "build:registry": "pnpm --filter sbean build:registry && vp fmt public/r --write",
    "build:schema": "pnpm --filter sbean build:schema",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@soybeanjs/headless": "workspace:^",
    "@soybeanjs/ui": "workspace:^",
    "es-toolkit": "^1.47.1",
    "pinia": "^3.0.4",
    "sbean": "workspace:^",
    "shiki": "^4.2.0",
    "valibot": "^1.4.1",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shikijs/markdown-exit": "^4.2.0",
    "@unhead/vue": "^3.1.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "lightningcss": "^1.32.0",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^32.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-meta-layouts": "^0.6.1",
    "vite-ssg": "^28.3.0",
    "vite-ssg-sitemap": "^0.10.0"
  },
  "packageManager": "pnpm@11.7.0"
}
